#line 34
	if (!replace_mask_allows(_source_static_data, _target_static_data)) {
#line 34
		return false;
#line 34
	}
#line 34
	if (elem_is_empty(_target_static_data)) {
#line 34
		return true;
#line 34
	}
#line 34
	if (_source_static_data.id == _target_static_data.id) {
#line 34
