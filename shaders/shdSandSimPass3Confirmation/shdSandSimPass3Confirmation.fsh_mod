int bitwise_and(int _left, int _right) {
#line 34
	int _result = 0;
#line 34
	for (int i = 0; i < 32; ++i) {
#line 34
		int _bit_value = int(pow(2.0, float(i)));
#line 34
		bool _left_has_bit = mod(float(_left), float(_bit_value * 2)) >= float(_bit_value);
#line 34
		bool _right_has_bit = mod(float(_right), float(_bit_value * 2)) >= float(_bit_value);
#line 34
		if (_left_has_bit && _right_has_bit) {
#line 34
			_result += _bit_value;
#line 34
		}
#line 34
	}
#line 34
	return _result;
#line 34
}
#line 34
int bitwise_or(int x, int y) {
#line 34
    int result = 0;
#line 34
    for (int i = 0; i < 8; ++i) {
#line 34
        int bit = int(pow(2.0, float(i)));
#line 34
        if (mod(float(x), float(2 * bit)) >= float(bit) ||
#line 34
            mod(float(y), float(2 * bit)) >= float(bit)) {
#line 34
            result += bit;
#line 34
        }
#line 34
    }
#line 34
    return result;
#line 34
}
#line 34
int bitwise_xor(int x, int y) {
#line 34
    int result = 0;
#line 34
    for (int i = 0; i < 8; ++i) {
#line 34
        int bit = int(pow(2.0, float(i)));
#line 34
        bool a = mod(float(x), float(2 * bit)) >= float(bit);
#line 34
        bool b = mod(float(y), float(2 * bit)) >= float(bit);
#line 34
        if (a != b) {
#line 34
            result += bit;
#line 34
        }
#line 34
    }
#line 34
    return result;
#line 34
}
#line 34
int bitwise_not(int x, int bit_count) {
#line 34
    return int(pow(2.0, float(bit_count)) - 1.0) - x;
#line 34
}
