ElementDynamicData ununpack_elem_dynamic_data(vec4 pixel) {
#line 33
	ElementDynamicData elem_dynamic_data;
#line 33
	elem_dynamic_data.id = elem_get_index(pixel);
#line 33
	elem_dynamic_data.static_data = get_element_static_data(elem_dynamic_data.id);
#line 33
	int g = float_to_byte(pixel.g);
#line 33
	elem_dynamic_data.custom_data = float_to_byte(pixel.b);
#line 33
	elem_dynamic_data.y_dir = bitwise_and(bit_shift_right(g, 7), 1);
#line 33
	elem_dynamic_data.y_speed = bitwise_and(bit_shift_right(g, 4), 7);
#line 33
	elem_dynamic_data.x_dir = bitwise_and(bit_shift_right(g, 3), 1);
#line 33
	elem_dynamic_data.x_speed = bitwise_and(g, 7);
#line 33
	float x_norm = float(elem_dynamic_data.x_speed) / 7.0;
#line 33
	float y_norm = float(elem_dynamic_data.y_speed) / 7.0;
#line 33
	float x_signed = x_norm * (elem_dynamic_data.x_dir == 0 ? 1.0 : -1.0);
#line 33
	float y_signed = y_norm * (elem_dynamic_data.y_dir == 0 ? 1.0 : -1.0);
#line 33
	elem_dynamic_data.vel = vec2(
#line 33
		x_signed * float(elem_dynamic_data.static_data.max_vel_x),
#line 33
		y_signed * float(elem_dynamic_data.static_data.max_vel_y)
#line 33
	);
#line 33
	return elem_dynamic_data;
#line 33
}
#line 33
vec4 pack_elem_dynamic_data(in ElementDynamicData elem_dynamic_data) {
#line 33
	int g = 0;
#line 33
	float max_vel_x = max(elem_dynamic_data.static_data.max_vel_x, 0.0001);
#line 33
	float max_vel_y = max(elem_dynamic_data.static_data.max_vel_y, 0.0001);
#line 33
	int x_speed = int(round(clamp(abs(elem_dynamic_data.vel.x) / max_vel_x, 0.0, 1.0) * 7.0));
#line 33
	int y_speed = int(round(clamp(abs(elem_dynamic_data.vel.y) / max_vel_y, 0.0, 1.0) * 7.0));
#line 33
	int x_dir = elem_dynamic_data.vel.x < 0.0 ? 1 : 0;
#line 33
	int y_dir = elem_dynamic_data.vel.y < 0.0 ? 1 : 0;
#line 33
	g = bitwise_or(g, bit_shift_left(clamp(y_dir, 0, 1), 7));
#line 33
	g = bitwise_or(g, bit_shift_left(clamp(y_speed, 0, 7), 4));
#line 33
	g = bitwise_or(g, bit_shift_left(clamp(x_dir, 0, 1), 3));
#line 33
	g = bitwise_or(g, clamp(x_speed, 0, 7));
#line 33
	float g_float = byte_to_float(g);
#line 33
	float r_float = byte_to_float(elem_dynamic_data.id);
#line 33
	float b_float = byte_to_float(clamp(elem_dynamic_data.custom_data, 0, 255));
#line 33
	return vec4(r_float, g_float, b_float, 1.0);
#line 33
}
