int bitwise_xor(int x, int y) {
#line 33
    int result = 0;
#line 33
    for (int i = 0; i < 8; ++i) {
#line 33
        int bit = int(pow(2.0, float(i)));
#line 33
        bool a = mod(float(x), float(2 * bit)) >= float(bit);
#line 33
        bool b = mod(float(y), float(2 * bit)) >= float(bit);
#line 33
        if (a != b) {
#line 33
            result += bit;
#line 33
        }
#line 33
    }
#line 33
    return result;
#line 33
}
